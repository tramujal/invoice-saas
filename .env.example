# Copy to .env and fill in real values. Never commit the real .env file.

# --- Backend (app/) ---

# SQLAlchemy database URL. Defaults to a local SQLite file if unset.
# For Postgres, either "postgresql://..." or "postgres://..." is accepted —
# both are automatically rewritten to use the psycopg3 driver.
DATABASE_URL=sqlite:///./invoices.db
# DATABASE_URL=postgresql://user:password@localhost:5432/invoices

# Secret used to sign JWT access tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be set to a real secret before deploying — the app falls back to an
# insecure default (with a warning) if this is unset.
JWT_SECRET_KEY=

# Access token lifetime, in minutes. Defaults to 1440 (24 hours).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# "development" (default) or "production". When "production", the app
# refuses to start unless JWT_SECRET_KEY is set to a real secret.
ENVIRONMENT=development

# Comma-separated list of frontend origins allowed to call this API.
# Defaults to the local Next.js dev origins when unset.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# --- Frontend (frontend/) ---

# Default API base URL shown on the login page.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
