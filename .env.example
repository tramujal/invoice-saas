# Copy to .env and fill in real values. Never commit the real .env file.

# --- Backend (app/) ---

# SQLAlchemy database URL. Defaults to a local SQLite file if unset.
# For Postgres, either "postgresql://..." or "postgres://..." is accepted —
# both are automatically rewritten to use the psycopg3 driver.
DATABASE_URL=sqlite:///./invoices.db
# DATABASE_URL=postgresql://user:password@localhost:5432/invoices

# Secret used to sign JWT access tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be set to a real secret before deploying — the app falls back to an
# insecure default (with a warning) if this is unset.
JWT_SECRET_KEY=

# Access token lifetime, in minutes. Defaults to 1440 (24 hours).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# "development" (default) or "production". When "production", the app
# refuses to start unless JWT_SECRET_KEY is set to a real secret.
ENVIRONMENT=development

# Comma-separated list of frontend origins allowed to call this API.
# Defaults to the local Next.js dev origins when unset.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Resend (https://resend.com) — required only for POST .../send-email and
# for actually delivering password-reset emails. Without these, sending
# fails silently server-side (forgot-password still returns its generic
# success response either way) and the invoice send-email endpoint returns
# 503; everything else works unaffected.
RESEND_API_KEY=
EMAIL_FROM=invoices@yourdomain.com

# Base URL of the deployed frontend, used to build the password-reset link
# sent by email (<FRONTEND_BASE_URL>/reset-password?token=...). Defaults to
# the local Next.js dev origin when unset.
FRONTEND_BASE_URL=http://localhost:3000

# AI Business Assistant (POST .../assistant/chat) — calls Anthropic's
# Messages API. Without ANTHROPIC_API_KEY set, the endpoint returns a clean
# 503 ("AI assistant is not configured") and nothing else in the app is
# affected.
ANTHROPIC_API_KEY=
# The model id to call. In development (ENVIRONMENT unset or not
# "production"), an unset AI_MODEL falls back to "claude-sonnet-5" with a
# logged warning — a convenience for local testing only. In production
# (ENVIRONMENT=production), AI_MODEL MUST be set explicitly: the app will
# not silently guess a model id that could become invalid as models are
# retired, since that assumption is exactly what led to this being
# required rather than hardcoded. See app/ai/factory.py.
AI_MODEL=
# Maximum tokens the assistant may generate in a single reply.
AI_MAX_OUTPUT_TOKENS=1024
# How long to wait for the provider before giving up (seconds).
AI_REQUEST_TIMEOUT_SECONDS=30
# Input validation limits for the chat endpoint — conservative defaults,
# rarely need changing. See app/ai/limits.py.
AI_MAX_USER_MESSAGE_LENGTH=2000
AI_MAX_HISTORY_MESSAGES=12
AI_MAX_HISTORY_MESSAGE_LENGTH=2000
AI_MAX_HISTORY_TOTAL_CHARS=8000
AI_MAX_CONTEXT_CHARS=6000

# --- Frontend (frontend/) ---

# Default API base URL shown on the login page.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
