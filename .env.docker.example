# Optional overrides for `docker compose up --build` (see docker-compose.yml).
#
# `docker compose up --build` works with NO .env file present at all --
# docker-compose.yml already has safe local defaults for everything else
# (database credentials, JWT_SECRET_KEY, CORS, etc.) hardcoded directly, so
# they can't be silently overridden by a stray .env left over from the
# non-Docker setup (see the comment at the top of docker-compose.yml).
#
# Copy this file to `.env` at the repo root ONLY if you want to enable real
# email sending or the AI Business Assistant locally against Docker. Never
# commit the real .env file.

# --- Email (Resend) ---
# Required together — required only for POST .../send-email and for
# actually delivering password-reset emails. Without these, the app starts
# fine and those two flows return a clean 503 instead.
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev

# --- AI Business Assistant ---
# Without these, the app starts fine and POST .../assistant/chat returns a
# clean 503 ("AI assistant is not configured"). See app/ai/factory.py.
AI_PROVIDER=anthropic
# Required when AI_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
# Required when AI_PROVIDER=gemini.
GEMINI_API_KEY=
# ENVIRONMENT=development inside this compose stack, so AI_MODEL may be
# left unset for local testing (falls back to a provider default) -- set it
# explicitly here to test a specific model.
AI_MODEL=
